      "source": [
        "# Prime Number Checker\n",
        "\n",
        "number = int(input(\"Enter a number: \"))\n",
        "\n",
        "count = 0\n",
        "\n",
        "for i in range(1, number + 1):\n",
        "\n",
        "    if number % i == 0:\n",
        "        count = count + 1\n",
        "\n",
        "if count == 2:\n",
        "    print(number, \"is a Prime Number\")\n",
        "else:\n",
        "    print(number, \"is Not a Prime Number\")"
      ]
    }
  ]
}